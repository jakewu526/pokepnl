generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CardSet {
  id             String   @id @default(cuid())
  name           String
  series         String?
  releaseDate    DateTime?
  totalCards     Int?
  code           String?
  logoUrl        String?
  symbolUrl      String?
  pokemonTcgIoId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cards          Card[]
  sealedProducts SealedProduct[]
}

model Card {
  id                 String   @id @default(cuid())
  setId              String
  number             String
  name               String
  rarity             String?
  supertype          String?
  subtypes           String[]
  imageUrl           String?
  pokemonTcgIoId     String?  @unique
  tcgplayerProductId String?  @unique
  pricechartingId    String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  set            CardSet         @relation(fields: [setId], references: [id])
  priceSnapshots PriceSnapshot[]
  collectionItems CollectionItem[]
  transactions    Transaction[]
  watchlistItems  WatchlistItem[]

  @@index([setId, number])
  @@index([name])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collectionItems CollectionItem[]
  transactions    Transaction[]
  watchlistItems  WatchlistItem[]
}

model CollectionItem {
  id              String   @id @default(cuid())
  userId          String
  cardId          String?
  sealedProductId String?
  condition       String?
  quantity        Int      @default(1)
  costPerUnit     Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  card          Card?          @relation(fields: [cardId], references: [id])
  sealedProduct SealedProduct? @relation(fields: [sealedProductId], references: [id])

  @@unique([userId, cardId, condition])
  @@unique([userId, sealedProductId, condition])
  @@index([userId])
}

model WatchlistItem {
  id              String   @id @default(cuid())
  userId          String
  cardId          String?
  sealedProductId String?
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  card          Card?          @relation(fields: [cardId], references: [id])
  sealedProduct SealedProduct? @relation(fields: [sealedProductId], references: [id])

  @@unique([userId, cardId])
  @@unique([userId, sealedProductId])
  @@index([userId])
}

model Transaction {
  id               String   @id @default(cuid())
  userId           String
  cardId           String?
  sealedProductId  String?
  itemName         String
  condition        String?
  quantity         Int
  costPerUnit      Decimal? @db.Decimal(10, 2)
  salePricePerUnit Decimal  @db.Decimal(10, 2)
  profit           Decimal? @db.Decimal(10, 2)
  soldAt           DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  card          Card?          @relation(fields: [cardId], references: [id], onDelete: SetNull)
  sealedProduct SealedProduct? @relation(fields: [sealedProductId], references: [id], onDelete: SetNull)

  @@index([userId, soldAt])
}

enum SealedProductType {
  BOOSTER_BOX
  BOOSTER_PACK
  ELITE_TRAINER_BOX
  BUNDLE
  BLISTER
  COLLECTION_BOX
  TIN
  OTHER
}

model SealedProduct {
  id                 String            @id @default(cuid())
  setId              String?
  name               String
  type               SealedProductType
  imageUrl           String?
  tcgplayerProductId String?           @unique
  pricechartingId    String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  set             CardSet?         @relation(fields: [setId], references: [id])
  priceSnapshots  PriceSnapshot[]
  collectionItems CollectionItem[]
  transactions    Transaction[]
  watchlistItems  WatchlistItem[]

  @@unique([setId, name])
  @@index([name])
}

enum PriceSource {
  TCGPLAYER
  CARDMARKET
  PRICECHARTING
  EBAY
}

enum PriceType {
  MARKET
  LOW
  MID
  HIGH
  DIRECT_LOW
}

model PriceSnapshot {
  id              String    @id @default(cuid())
  cardId          String?
  sealedProductId String?
  source          PriceSource
  priceType       PriceType
  condition       String?
  price           Decimal   @db.Decimal(10, 2)
  capturedAt      DateTime  @default(now())
  capturedDate    DateTime  @default(now()) @db.Date

  card          Card?          @relation(fields: [cardId], references: [id])
  sealedProduct SealedProduct? @relation(fields: [sealedProductId], references: [id])

  @@unique([cardId, sealedProductId, source, priceType, condition, capturedDate])
  @@index([cardId, capturedAt])
  @@index([sealedProductId, capturedAt])
}
