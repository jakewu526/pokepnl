# Copy this file to `.env` and fill in the values for your setup.
#
# This app has no separate API layer -- Server Components and Server Actions
# query Postgres directly through Prisma. That means "the server" is really
# just "wherever Postgres lives." There are two ways to run this app:
#
# ---------------------------------------------------------------------------
# OPTION A -- Server device (runs its own Postgres via `docker compose up -d`)
# ---------------------------------------------------------------------------
# DATABASE_URL points at your own local Postgres. No changes needed beyond
# filling in the password you set in docker-compose.yml.
#
#   DATABASE_URL="postgresql://pokemon:<password>@localhost:5432/pokemon_tcg?schema=public"
#
# ---------------------------------------------------------------------------
# OPTION B -- Client device (shares another device's database over Tailscale)
# ---------------------------------------------------------------------------
# Install Tailscale (https://tailscale.com) and join the same tailnet as the
# server device. Then point DATABASE_URL at the server's Tailscale hostname
# (find it in the Tailscale admin console, or `tailscale status` on the
# server -- with MagicDNS enabled it looks like `<device-name>.<tailnet>.ts.net`)
# instead of `localhost`:
#
#   DATABASE_URL="postgresql://pokemon:<password>@<server-tailscale-hostname>:5432/pokemon_tcg?schema=public"
#
# Client devices do NOT need Docker, and should NOT run `db:migrate` or any
# `ingest:*`/`snapshot:*` script -- those stay server-only. Just:
#   git clone, npm install, cp .env.example .env (fill in DATABASE_URL),
#   npx prisma generate, npm run dev.
DATABASE_URL="postgresql://pokemon:pokemon@localhost:5432/pokemon_tcg?schema=public"

# Server device only. Docker Compose auto-loads this file, so this is the
# single source of truth for the Postgres password -- docker-compose.yml
# references it as ${POSTGRES_PASSWORD} rather than hardcoding it. Must
# match the password portion of DATABASE_URL above.
POSTGRES_PASSWORD=""

# ---------------------------------------------------------------------------
# OPTION C -- UAT/staging instance (own app checkout, own DB, own port)
# ---------------------------------------------------------------------------
# The prod server device's docker-compose.yml also runs a second Postgres
# container (`postgres-uat`, host port 5433, database `pokemon_tcg_uat`) so
# UAT can be tested without touching prod data. This password is only read
# by the prod device's `docker compose up -d` (via ${POSTGRES_UAT_PASSWORD}
# in docker-compose.yml) -- leave blank on client devices and on the UAT
# checkout itself.
POSTGRES_UAT_PASSWORD=""
#
# The UAT app checkout's own .env should instead set:
#   DATABASE_URL="postgresql://pokemon:<uat-password>@localhost:5433/pokemon_tcg_uat?schema=public"
# and run on its own port via NSSM (`next start -p 3001`) so it never
# collides with the prod instance on port 3000.

# Secret key used to sign session cookies (generate via `openssl rand -base64 32`).
# Client devices can reuse the server's value or generate their own -- each
# Next.js instance issues/decrypts its own cookies independently, so either
# works, but reusing the server's keeps things predictable.
SESSION_SECRET=""

# API keys for data ingestion (server device only -- leave blank on clients).
# TCGplayer and PriceCharting are dormant/optional -- see scripts/snapshot-prices.ts,
# scripts/ingest-sealed-products.ts, scripts/link-tcgplayer-ids.ts, and
# scripts/backfill-pricecharting-history.ts. Card pricing works today without
# them via ingest-cards.ts (pokemontcg.io mirrors TCGplayer/Cardmarket prices).
TCGPLAYER_PUBLIC_KEY=""
TCGPLAYER_PRIVATE_KEY=""
PRICECHARTING_API_TOKEN=""

# eBay Buy Browse API -- free self-serve registration at
# https://developer.ebay.com/my/keys (no partner approval needed).
# Used as a sealed-product price proxy in scripts/ingest-sealed-products-ebay.ts.
# Server device only -- leave blank on clients.
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""

# Google Sign-In. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials (Application type: "Web
# application"). The redirect URI is derived automatically at request time
# from whatever host the browser used (see lib/google-oauth.ts), so it works
# both from the server device's localhost and from client devices browsing
# to the server's Tailscale hostname. Google still requires each one to be
# whitelisted exactly, though -- add every origin used to reach the app as
# an Authorized redirect URI on the OAuth client, e.g.:
#   http://localhost:3000/api/auth/google/callback
#   http://<server-tailscale-hostname>:3000/api/auth/google/callback
#   https://<your-domain>/api/auth/google/callback
#
# Client devices browse directly to the server device's app -- they don't
# run their own instance -- so these only need to be set in the server
# device's .env.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
